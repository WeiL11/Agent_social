# Copy to .env for local non-docker runs. docker-compose sets these directly.
ENVIRONMENT=dev
DATABASE_URL=postgresql+psycopg://app:app@localhost:5432/persona
CORS_ORIGINS=http://localhost:3000

# Supabase Auth (production). Leave blank in dev to use the X-Dev-User fallback.
SUPABASE_JWT_SECRET=
SUPABASE_PROJECT_URL=

# LLM provider for character flavor (cold-start only). "none" = templated stub.
LLM_PROVIDER=none
